// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  password     String?
  name         String
  phone        String?   @unique
  about        String?
  faculty      String?
  department   String?
  role         String
  office       String?
  matricNumber String?   @unique
  googleId     String?   @unique
  
  studentProfile Student?
  managedCohorts Cohort[]  @relation("RepCohorts")
  taughtCourses  Course[]  @relation("LecturerCourses")
  trackers       Tracker[]
  updates        CourseUpdate[]
  joinedCohort   Cohort?   @relation("CohortViewers", fields: [joinedCohortId], references: [id])
  joinedCohortId String?
  
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Cohort {
  id          String    @id @default(cuid())
  faculty     String
  department  String
  program     String
  level       Level
  
  courseRepId String
  courseRep   User      @relation("RepCohorts", fields: [courseRepId], references: [id])
  
  students    Student[]
  courses     Course[]  @relation("CohortCourses")
  trackers    Tracker[]
  viewers     User[]    @relation("CohortViewers")
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  @@unique([program, level, department])
}

model Student {
  id           String          @id @default(cuid())
  userId       String?         @unique
  user         User?           @relation(fields: [userId], references: [id], onDelete: Cascade)
  cohortId     String
  cohort       Cohort          @relation(fields: [cohortId], references: [id], onDelete: Cascade)
  fullName     String
  matricNumber String          @unique
  gender       Gender
  records      TrackerRecord[]
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
}

model Course {
  id          String         @id @default(cuid())
  code        String         @unique
  name        String
  semester    String?
  
  lecturerId  String
  lecturer    User           @relation("LecturerCourses", fields: [lecturerId], references: [id])
  
  cohorts     Cohort[]       @relation("CohortCourses")
  trackers    Tracker[]
  updates     CourseUpdate[]
  
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model CourseUpdate {
  id        String   @id @default(cuid())
  content   String
  courseId  String
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Tracker {
  id        String          @id @default(cuid())
  name      String
  type      TrackerType
  date      DateTime        @default(now())
  
  courseId  String
  course    Course          @relation(fields: [courseId], references: [id], onDelete: Cascade)
  
  cohortId  String
  cohort    Cohort          @relation(fields: [cohortId], references: [id], onDelete: Cascade)
  
  userId    String
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  records   TrackerRecord[]
  
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
}

model TrackerRecord {
  id        String       @id @default(cuid())
  trackerId String
  tracker   Tracker      @relation(fields: [trackerId], references: [id], onDelete: Cascade)
  studentId String
  student   Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  status    RecordStatus
  notes     String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@unique([trackerId, studentId])
}

enum Level {
  LEVEL_100
  LEVEL_200
  LEVEL_300
  LEVEL_400
  LEVEL_500
}

enum Gender {
  MALE
  FEMALE
}

enum TrackerType {
  ATTENDANCE
  ASSIGNMENT
}

enum RecordStatus {
  PRESENT
  ABSENT
  LATE
  SUBMITTED
  NOT_SUBMITTED
  PENDING
}